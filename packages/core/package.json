{
  "name": "@chilekit/core",
  "version": "0.1.0",
  "description": "Tipos y utilidades base de ChileKit.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap --clean",
    "clean": "rm -rf dist",
    "test": "vitest run --config ../../vitest.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
